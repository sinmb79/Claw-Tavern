    "Base Sepolia USDC defaults to 0x036CbD53842c5426634e7929541eC2318f3dCF7e from Base documentation.",
    "ETH/USD defaults to 0x4adc67d868ac7a395922e35c834e3bfa52e3f9c0 for Base Sepolia.",
