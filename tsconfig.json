{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "node",
      "hardhat"
    ]
  },
  "include": [
    "hardhat.config.ts",
    "deploy/**/*.ts",
    "scripts/**/*.ts",
    "test/**/*.ts"
  ]
}
