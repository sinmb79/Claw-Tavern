{
  "name": "claw-tavern-hardhat",
  "private": true,
  "version": "0.1.0",
  "description": "Base Sepolia deployment project for Claw Tavern contracts",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "audit:fuzz": "node scripts/run-forge.js test --match-path test/fuzz/*.t.sol -vvv",
    "audit:slither": "python -m slither . --config-file slither.config.json",
    "audit:slither:install": "python -m pip install slither-analyzer",
    "cancel:automation": "hardhat run scripts/cancel-automation-upkeeps.ts --network baseSepolia",
    "cancel:automation:mainnet": "hardhat run scripts/cancel-automation-upkeeps.ts --network base",
    "cancel:automation:base": "hardhat run scripts/cancel-automation-upkeeps.ts --network base",
    "cancel:automation:base:wait": "set AUTOMATION_WAIT_FOR_WITHDRAW=1&& hardhat run scripts/cancel-automation-upkeeps.ts --network base",
    "cancel:automation:mainnet:wait": "set AUTOMATION_WAIT_FOR_WITHDRAW=1&& hardhat run scripts/cancel-automation-upkeeps.ts --network base",
    "cancel:automation:sepolia": "hardhat run scripts/cancel-automation-upkeeps.ts --network baseSepolia",
    "cancel:automation:sepolia:wait": "set AUTOMATION_WAIT_FOR_WITHDRAW=1&& hardhat run scripts/cancel-automation-upkeeps.ts --network baseSepolia",
    "cancel:automation:wait": "set AUTOMATION_WAIT_FOR_WITHDRAW=1&& hardhat run scripts/cancel-automation-upkeeps.ts --network baseSepolia",
    "clean": "hardhat clean",
    "cleanup:automation": "hardhat run scripts/cleanup-legacy-automation.ts --network baseSepolia",
    "cleanup:automation:execute": "set AUTOMATION_EXECUTE=1&& hardhat run scripts/cleanup-legacy-automation.ts --network baseSepolia",
    "cleanup:automation:base": "hardhat run scripts/cleanup-legacy-automation.ts --network base",
    "cleanup:automation:base:execute": "set AUTOMATION_EXECUTE=1&& hardhat run scripts/cleanup-legacy-automation.ts --network base",
    "cleanup:legacy-automation": "hardhat run scripts/cleanup-legacy-automation.ts --network baseSepolia",
    "compile": "hardhat compile",
    "deploy:baseSepolia": "hardhat run deploy/01_deploy.ts --network baseSepolia",
    "deploy:automation-router:baseSepolia": "hardhat run deploy/06_deploy_automation_router.ts --network baseSepolia",
    "deploy:client-rpg:base": "hardhat run deploy/09_deploy_client_rpg.ts --network base",
    "deploy:client-rpg:baseSepolia": "hardhat run deploy/09_deploy_client_rpg.ts --network baseSepolia",
    "deploy:nft-system:base": "hardhat run deploy/09_nft_system.ts --network base",
    "deploy:nft-system:baseSepolia": "hardhat run deploy/09_nft_system.ts --network baseSepolia",
    "deploy:governance:baseSepolia": "hardhat run deploy/05_deploy_governance.ts --network baseSepolia",
    "deploy:mainnet": "hardhat run deploy/08_mainnet_deploy.ts --network base",
    "deploy:full-v2:base": "hardhat run deploy/11_full_redeploy_v2.ts --network base",
    "deploy:full-v2:baseSepolia": "hardhat run deploy/11_full_redeploy_v2.ts --network baseSepolia",
    "deploy:service-marketplace:base": "hardhat run deploy/10_service_marketplace.ts --network base",
    "deploy:service-marketplace:baseSepolia": "hardhat run deploy/10_service_marketplace.ts --network baseSepolia",
    "deploy:subscription:base": "hardhat run deploy/10_deploy_subscription.ts --network base",
    "deploy:subscription:baseSepolia": "hardhat run deploy/10_deploy_subscription.ts --network baseSepolia",
    "deploy:phase3:baseSepolia": "hardhat run deploy/07_phase3_redeploy.ts --network baseSepolia",
    "deploy:phase2:baseSepolia": "hardhat run deploy/04_phase2_redeploy.ts --network baseSepolia",
    "deploy:sepolia": "hardhat run deploy/07_phase3_redeploy.ts --network baseSepolia",
    "deploy:staking:baseSepolia": "hardhat run deploy/03_deploy_staking.ts --network baseSepolia",
    "e2e:baseSepolia": "npx hardhat run scripts/e2e-testnet-qa.ts --network baseSepolia",
    "generate:thresholds": "ts-node scripts/generate-thresholds.ts",
    "nft:generate-metadata": "ts-node scripts/nft/03_generate-metadata.ts",
    "nft:register-batches": "ts-node scripts/register-nft-items.ts",
    "nft:register-data": "ts-node scripts/nft/06_generate-register-data.ts",
    "nft:standardize": "ts-node scripts/nft/01_standardize-images.ts",
    "nft:standardize:prune": "ts-node scripts/nft/01_standardize-images.ts --prune-source-duplicates",
    "nft:upload-images": "ts-node scripts/nft/02_upload-images-pinata.ts",
    "nft:upload-images:directory": "ts-node scripts/nft/02_upload-images-pinata.ts --mode=directory",
    "nft:upload-metadata": "ts-node scripts/nft/04_upload-metadata-pinata.ts",
    "nft:verify": "ts-node scripts/nft/05_verify-metadata.ts",
    "register:automation": "hardhat run scripts/register-automation.ts --network baseSepolia",
    "register:automation:mainnet": "hardhat run scripts/register-automation.ts --network base",
    "register:automation:sepolia": "hardhat run scripts/register-automation.ts --network baseSepolia",
    "register:automation:base": "hardhat run scripts/register-automation.ts --network base",
    "smoke:baseSepolia": "hardhat run scripts/sepolia-smoke-test.ts --network baseSepolia",
    "smoke:mainnet": "hardhat run scripts/phase2-readonly-smoke.ts --network base",
    "smoke:phase2:base": "hardhat run scripts/phase2-readonly-smoke.ts --network base",
    "smoke:phase2:baseSepolia": "hardhat run scripts/phase2-readonly-smoke.ts --network baseSepolia",
    "smoke:sepolia": "hardhat run scripts/phase2-readonly-smoke.ts --network baseSepolia",
    "setup:automation:baseSepolia": "hardhat run deploy/02_setup_automation.ts --network baseSepolia",
    "test": "hardhat test",
    "verify:automation": "hardhat run scripts/verify-automation-health.ts --network baseSepolia",
    "verify:automation:mainnet": "hardhat run scripts/verify-automation-health.ts --network base",
    "verify:automation:sepolia": "hardhat run scripts/verify-automation-health.ts --network baseSepolia",
    "verify:automation:base": "hardhat run scripts/verify-automation-health.ts --network base",
    "verify:full-deploy:base": "hardhat run scripts/verify-full-deploy.ts --network base",
    "verify:full-deploy:baseSepolia": "hardhat run scripts/verify-full-deploy.ts --network baseSepolia",
    "verify:baseSepolia": "hardhat run scripts/verify-contracts.ts --network baseSepolia"
  },
  "dependencies": {
    "@chainlink/contracts": "^1.5.0",
    "@openzeppelin/contracts": "^5.6.1",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@pinata/sdk": "^2.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.5.2",
    "chai": "^4.5.0",
    "ethers": "^6.16.0",
    "forge-std": "^1.1.2",
    "hardhat": "^2.28.6",
    "p-limit": "^7.3.0",
    "sharp": "^0.34.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
